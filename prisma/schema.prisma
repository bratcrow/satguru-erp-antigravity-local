generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id             String           @id @default(cuid())
  sku            String           @unique
  name           String
  stock          Float            @default(0) // Kg or Units
  retailPrice    Float
  wholesalePrice Float
  recipes        Recipe[]
  orderItems     OrderItem[]
  truckInventory TruckInventory[]
}

model RawMaterial {
  id      String   @id @default(cuid())
  name    String
  stock   Float    @default(0)
  unit    String   // Kg, Liters, etc.
  recipes Recipe[]
}

model Recipe {
  id            String      @id @default(cuid())
  product       Product     @relation(fields: [productId], references: [id])
  productId     String
  rawMaterial   RawMaterial @relation(fields: [rawMaterialId], references: [id])
  rawMaterialId String
  quantityPerKg Float       // Amount of raw material needed per 1kg of Product
}

model Customer {
  id             String               @id @default(cuid())
  name           String
  phone          String?
  address        String?
  route          String
  type           String               // RETAIL or WHOLESALE
  pendingBalance Float                @default(0)
  createdAt      DateTime             @default(now())
  orders         Order[]
  transactions   PaymentTransaction[]
  bills          POSBill[]
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  role      String
  phone     String
  createdAt DateTime @default(now())
}

model PaymentTransaction {
  id         String   @id @default(cuid())
  customerId String
  amount     Float
  type       String   // CREDIT_CLEAR, ADVANCE, etc.
  notes      String?
  createdAt  DateTime @default(now())
  
  customer   Customer @relation(fields: [customerId], references: [id])
}

model Order {
  id            String      @id @default(cuid())
  customerId    String
  routeDate     DateTime
  total         Float
  paymentMethod String      @default("CASH") // CASH, UPI, PENDING, CHEQUE
  status        String      @default("PENDING") // PENDING, DELIVERED, CANCELLED
  createdAt     DateTime    @default(now())

  customer Customer    @relation(fields: [customerId], references: [id])
  items    OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Float
  price     Float   // Stored at time of order creation

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model TruckTrip {
  id            String           @id @default(cuid())
  routeDate     DateTime
  route         String
  status        String           @default("PLANNED") // PLANNED, OUT, RETURNED
  driverName    String?
  employee1Name String?
  employee2Name String?
  inventory     TruckInventory[]
}

model TruckInventory {
  id          String    @id @default(cuid())
  trip        TruckTrip @relation(fields: [tripId], references: [id])
  tripId      String
  product     Product   @relation(fields: [productId], references: [id])
  productId   String
  loadedQty   Float     @default(0) // Total loaded (Orders + Manual)
  returnedQty Float     @default(0) // Good stock returned
  soldQty     Float     @default(0) // Calculated: loaded - returned - wastage - damage
  wastage     Float     @default(0)
  damage      Float     @default(0)
}

model POSBill {
  id            String    @id @default(cuid())
  customer      Customer? @relation(fields: [customerId], references: [id])
  customerId    String?   // Optional for walk-in
  date          DateTime  @default(now())
  total         Float
  discount      Float     @default(0)
  tax           Float     @default(0)
  paymentMethod String    // "CASH", "UPI", "CHEQUE", "PENDING"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  pinCode      String?  // 6-digit PIN for quick login
  role         String   // ADMIN, SALES_PERSON, MANAGER, ACCOUNTANT
  allowedPages String   // JSON string of allowed page paths e.g. "['/pos', '/orders']"
  createdAt    DateTime @default(now())
}
